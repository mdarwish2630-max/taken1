RewriteEngine On
RewriteBase /takweenweb

DirectoryIndex public/index.php

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ public/index.php [QSA,L]

# Block PHP execution except index.php
<FilesMatch "\.php[0-9]?$">
    Order allow,deny
    Deny from all
</FilesMatch>
<Files "index.php">
    Order allow,deny
    Allow from all
</Files>

# Block sensitive file types
<FilesMatch "\.(env|log|sql|md|json|lock|yml|yaml|xml|ini|conf|sh|bak|dist)$">
    Order allow,deny
    Deny from all
</FilesMatch>

Options -Indexes
