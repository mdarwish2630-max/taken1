RewriteEngine On
RewriteBase /takweenweb

DirectoryIndex public/index.php

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ public/index.php [QSA,L]

# Block sensitive file types
<FilesMatch "\.(env|log|sql|md|json|lock|yml|yaml|xml|ini|conf|sh|bak|dist)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block sensitive config files
<FilesMatch "^(config|database|composer|package)\.(php|json|lock)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block direct access to app/vendor/core directories
<IfModule mod_rewrite.c>
    RewriteRule ^(app|vendor|core) - [F,L]
</IfModule>

Options -Indexes
